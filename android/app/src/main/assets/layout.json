    "bg1": "#2a0a0a",
    "bg2": "#6b1414",
    "bg3": "#8a1f1f",
    "gold": "#d9a441",
    "goldBright": "#f2cd6b",
    "ink": "#120404",
    "paper": "#e8dcc0",
    "accent": "#c0392b",
