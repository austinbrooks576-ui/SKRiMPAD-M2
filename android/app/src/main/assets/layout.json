    { "id": "synth", "type": "scope",       "title": "波 SYNTH + WAVE",   "grid_position": { "x": 1, "y": 6, "w": 4, "h": 2 }, "style_class": "glass" },
    { "id": "fx",    "type": "knob_matrix", "title": "効 FX PEDALS",      "grid_position": { "x": 5, "y": 7, "w": 4, "h": 1 }, "style_class": "glass" },
